# ── Shared ──────────────────────────────────────────────────────────────────
# A single AWS_REGION overrides the default in every agent module.
AWS_REGION=us-east-1
MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# ── History Tree agent ────────────────────────────────────────────────────────
# Bedrock Knowledge Base used by history_tree_report.
KNOWLEDGE_BASE_ID=your-history-kb-id

# ── Report Analysis agent ─────────────────────────────────────────────────────
# Knowledge Base + S3 used by report_* tools.
# (report_analysis reads KNOWLEDGE_BASE_ID too; if it differs from History Tree,
#  run the two agents against different regions/accounts or split the KB ids.)
S3_BUCKET=your-report-bucket
S3_PREFIX=report-analysis-agent/uploads/
DATA_SOURCE_ID=your-data-source-id
KB_SEARCH_TYPE=HYBRID
KB_NUMBER_OF_RESULTS=20
OUTPUT_DIR=output

# Optional web search providers for the Ranger agent (report_search_external_trends).
TAVILY_API_KEY=
EXA_API_KEY=

# ── HR Search agent ───────────────────────────────────────────────────────────
# S3 bucket holding structured_data.json / text_data.json / embeddings.json
# under S3_DATA_PREFIX. NOTE: hr_search reuses S3_BUCKET, so if HR and Report use
# different buckets, set them per-deployment or keep both datasets in one bucket.
S3_DATA_PREFIX=data
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_CLAUDE_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
